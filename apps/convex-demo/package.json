{
  "name": "@metacrdt/convex-demo",
  "version": "0.1.0",
  "description": "Convex reference application for the MetaCRDT dashboard and staffing vertical.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm --dir ../.. build:packages && convex dev",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "convex deploy",
    "deploy:static": "static-hosting deploy",
    "confect:codegen": "node ../../scripts/confect-codegen-sidecar.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:confect": "vitest run convex/confect.test.ts convex/complianceConfect.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@confect/core": "^8.0.0",
    "@confect/server": "^8.0.0",
    "@convex-dev/better-auth": "^0.12.3",
    "@convex-dev/static-hosting": "^0.1.3",
    "@metacrdt/collect": "workspace:*",
    "@metacrdt/convex": "workspace:*",
    "@metacrdt/core": "workspace:*",
    "@metacrdt/client": "workspace:*",
    "@metacrdt/dashboard": "workspace:*",
    "@metacrdt/query": "workspace:*",
    "@metacrdt/schema": "workspace:*",
    "@metacrdt/views": "workspace:*",
    "@metacrdt/views-react": "workspace:*",
    "@metacrdt/workflow": "workspace:*",
    "better-auth": "~1.6.15",
    "convex": "^1.40.0",
    "effect": "^3.21.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@confect/cli": "^8.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@metacrdt/testkit": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "convex-test": "^0.0.53",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
