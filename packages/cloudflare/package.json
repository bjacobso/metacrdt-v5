{
  "name": "@metacrdt/cloudflare",
  "version": "0.1.0",
  "description": "MetaCRDT Cloudflare target helpers: Durable Object storage-backed runtime services for event logs, HLC clocks, and per-replica sequencing.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "wrangler.example.toml"
  ],
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run --json"
  },
  "dependencies": {
    "@metacrdt/core": "0.1.0",
    "@metacrdt/query": "0.1.0",
    "@metacrdt/runtime": "0.1.0",
    "effect": "^3.21.3"
  },
  "devDependencies": {
    "@metacrdt/testkit": "0.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
