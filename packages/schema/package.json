{
  "name": "@metacrdt/schema",
  "version": "0.1.0",
  "description": "MetaCRDT schema-as-facts helpers: canonical schema entity ids, builtin cardinalities, value types, and bootstrap meta-attribute definitions.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run --json"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
