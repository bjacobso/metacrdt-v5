{
  "name": "@metacrdt/testkit",
  "version": "0.1.0",
  "description": "MetaCRDT target conformance helpers: reusable checks for runtime EventStore, anti-entropy, and deterministic fold convergence.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run --json"
  },
  "dependencies": {
    "@metacrdt/core": "0.1.0",
    "@metacrdt/query": "0.1.0",
    "@metacrdt/runtime": "0.1.0",
    "effect": "^3.21.3"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
