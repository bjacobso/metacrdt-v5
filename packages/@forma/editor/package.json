{
  "name": "@forma/editor",
  "version": "0.1.0",
  "description": "Forma editor: CodeMirror + React editor integration for the Forma language (via @forma/host).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./codemirror": {
      "types": "./src/codemirror/index.ts",
      "import": "./dist/codemirror/index.js",
      "default": "./src/codemirror/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./dist/react/index.js",
      "default": "./src/react/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "generate": "lezer-generator src/grammar/lisp.grammar -o src/grammar/parser.generated.ts && node -e \"const fs=require('fs'); for(const f of ['src/grammar/parser.generated.ts','src/grammar/parser.generated.terms.ts']){const c=fs.readFileSync(f,'utf8'); fs.writeFileSync(f,'// @ts-nocheck\\n'+c)}\"",
    "build": "npm run generate && tsdown",
    "test": "npm run generate && vitest --run",
    "typecheck": "npm run generate && tsc --noEmit",
    "clean": "rm -rf dist src/grammar/parser.generated.ts src/grammar/parser.generated.terms.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.11.0",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.8",
    "@forma/host": "workspace:*",
    "@lezer/highlight": "^1.2.1",
    "@lezer/lr": "^1.4.2",
    "effect": "^3.21.3"
  },
  "devDependencies": {
    "@lezer/generator": "^1.7.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
