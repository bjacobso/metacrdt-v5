opam-version: "2.0"
synopsis: "OCaml spike for the Open Ontology language compiler/interpreter engine"
description: "Runtime-loadable Open Ontology Lisp compiler/interpreter engine spike."
maintainer: "Open Ontology"
authors: "Open Ontology"
license: "UNLICENSED"
depends: [
  "ocaml" {>= "5.1"}
  "dune" {>= "3.17"}
  "js_of_ocaml" {with-test}
  "wasm_of_ocaml-compiler" {with-test}
]
build: [
  ["dune" "subst"] {dev}
  ["dune" "build" "-p" name "-j" jobs]
]
