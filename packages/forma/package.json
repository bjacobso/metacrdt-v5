{
  "name": "@metacrdt/forma",
  "version": "0.1.0",
  "description": "MetaCRDT Forma: the runtime-neutral Lisp/sexpr authoring language extracted from Open Ontology.",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./reader": "./src/Reader.ts",
    "./source": "./src/Source.ts",
    "./session": "./src/Session.ts",
    "./engine": "./src/Engine.ts",
    "./artifact": "./src/Artifact.ts",
    "./mechanics": "./src/Mechanics.ts",
    "./sexpr": "./src/SExpr.ts",
    "./expander": "./src/Expander.ts",
    "./evaluator": "./src/Evaluator.ts",
    "./vm": "./src/VM.ts",
    "./builtins": "./src/Builtins.ts",
    "./type": "./src/Type.ts",
    "./elaboration": "./src/Elaboration.ts",
    "./form": "./src/Form.ts",
    "./core-expr": "./src/CoreExpr.ts",
    "./env": "./src/Env.ts",
    "./diagnostic": "./src/Diagnostic.ts",
    "./formatter": "./src/Formatter.ts",
    "./editor": "./src/Editor.ts",
    "./lsp": "./src/LSP.ts",
    "./codegen": "./src/CodeGen.ts",
    "./descriptor-codegen": "./src/DescriptorCodegen.ts",
    "./descriptor": "./src/Descriptor.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "^3.21.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
