{
  "name": "@metacrdt/node",
  "version": "0.1.0",
  "description": "MetaCRDT Node target helpers: server-process memory/SQLite/Postgres runtime services, HTTP/SSE sync adapters, and a packaged dev server CLI.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dev-server": {
      "types": "./dist/dev-server.d.ts",
      "import": "./dist/dev-server.js"
    }
  },
  "bin": {
    "metacrdt-node-dev": "./dist/dev-server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run --json"
  },
  "dependencies": {
    "@metacrdt/core": "0.1.0",
    "@metacrdt/runtime": "0.1.0",
    "effect": "^3.21.3"
  },
  "devDependencies": {
    "@metacrdt/testkit": "0.1.0",
    "@types/node": "^24.10.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
