{
  "name": "@metacrdt/query",
  "version": "0.1.0",
  "description": "MetaCRDT query helpers: target-neutral Datalog clause parsing, term operations, projection, pagination, aggregation, and rule-locality analysis.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack:check": "node ../../scripts/pnpm-pack-check.mjs"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
