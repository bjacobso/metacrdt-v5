{
  "name": "@metacrdt/views-react",
  "version": "0.1.0",
  "description": "React renderer for MetaCRDT ViewSpec trees.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack:check": "node ../../scripts/pnpm-pack-check.mjs"
  },
  "dependencies": {
    "@metacrdt/views": "workspace:*",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
