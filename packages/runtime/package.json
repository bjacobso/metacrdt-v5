{
  "name": "@metacrdt/runtime",
  "version": "0.1.0",
  "description": "MetaCRDT runtime harness: target-neutral service interfaces, operation helpers, and an in-memory target for proving multi-runtime convergence contracts.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack:check": "node ../../scripts/pnpm-pack-check.mjs"
  },
  "dependencies": {
    "@metacrdt/core": "workspace:*",
    "@metacrdt/query": "workspace:*",
    "effect": "^3.21.3"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
