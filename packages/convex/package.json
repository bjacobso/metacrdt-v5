{
  "name": "@metacrdt/convex",
  "version": "0.1.0",
  "description": "MetaCRDT Convex target helpers: protocol metadata validators, Convex-row adapters, component-owned protocol log functions, projection visibility, and optional Confect integration utilities.",
  "type": "module",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./convex.config.js": "./src/component/convex.config.ts",
    "./convex.config": "./src/component/convex.config.ts",
    "./_generated/component.js": "./src/component/_generated/component.ts",
    "./_generated/component": "./src/component/_generated/component.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@metacrdt/core": "0.1.0",
    "convex": "^1.40.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
