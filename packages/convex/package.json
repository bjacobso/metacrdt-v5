{
  "name": "@metacrdt/convex",
  "version": "0.1.0",
  "description": "MetaCRDT Convex target helpers: protocol metadata validators, Convex-row adapters, component-owned protocol log/current projection/cardinality functions, and optional Confect integration utilities.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js"
    },
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts",
      "import": "./dist/component/_generated/component.js"
    },
    "./_generated/component": {
      "types": "./dist/component/_generated/component.d.ts",
      "import": "./dist/component/_generated/component.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack:check": "node ../../scripts/pnpm-pack-check.mjs"
  },
  "dependencies": {
    "@metacrdt/core": "workspace:*",
    "@metacrdt/runtime": "workspace:*",
    "convex": "^1.40.0",
    "effect": "^3.21.3"
  },
  "devDependencies": {
    "convex-test": "^0.0.53",
    "@metacrdt/testkit": "workspace:*",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
