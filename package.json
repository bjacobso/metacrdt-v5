{
  "name": "convex-triples",
  "version": "0.1.0",
  "description": "A reactive bitemporal triple store with a Datalog query engine, built on Convex.",
  "type": "module",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "packages/*",
    "packages/@forma/*"
  ],
  "scripts": {
    "dev": "npm run build:packages && convex dev",
    "dev:web": "vite",
    "build": "npm run build:packages && npm run build:app",
    "build:app": "vite build",
    "build:packages": "turbo run build --filter='./packages/*' --filter='./packages/@forma/*'",
    "preview": "vite preview",
    "deploy": "convex deploy",
    "deploy:static": "static-hosting deploy",
    "confect:codegen": "node scripts/confect-codegen-sidecar.mjs",
    "test": "npm run build:packages && vitest run",
    "test:watch": "vitest",
    "test:cloudflare": "npm test --workspace @metacrdt/cloudflare",
    "test:core": "npm test --workspace @metacrdt/core",
    "test:convex-package": "npm test --workspace @metacrdt/convex",
    "test:forma": "npm test --workspace @forma/ts",
    "test:forma-host": "npm test --workspace @forma/host",
    "test:local": "npm test --workspace @metacrdt/local",
    "test:query": "npm test --workspace @metacrdt/query",
    "test:runtime": "npm test --workspace @metacrdt/runtime",
    "test:schema": "npm test --workspace @metacrdt/schema",
    "test:confect": "vitest run convex/confect.test.ts convex/complianceConfect.test.ts",
    "test:packages": "turbo run test --filter='./packages/*' --filter='./packages/@forma/*'",
    "test:all": "npm run test:packages && npm test",
    "pack:packages": "turbo run pack:check --filter='./packages/*' --filter='./packages/@forma/*'",
    "typecheck": "npm run build:packages && npm run typecheck:packages && tsc --noEmit -p tsconfig.json",
    "typecheck:packages": "turbo run typecheck --filter='./packages/*' --filter='./packages/@forma/*'"
  },
  "license": "MIT",
  "dependencies": {
    "@confect/core": "^8.0.0",
    "@confect/server": "^8.0.0",
    "@convex-dev/static-hosting": "^0.1.3",
    "@metacrdt/views": "0.1.0",
    "convex": "^1.40.0",
    "effect": "^3.21.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@confect/cli": "^8.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "convex-test": "^0.0.53",
    "rolldown": "^1.1.0",
    "tailwindcss": "^4.3.0",
    "tsdown": "^0.22.2",
    "turbo": "^2.9.16",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
