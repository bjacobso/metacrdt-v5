{
  "name": "convex-triples",
  "version": "0.1.0",
  "description": "A reactive bitemporal triple store with a Datalog query engine, built on Convex.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "convex dev",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "convex deploy",
    "deploy:static": "static-hosting deploy",
    "confect:codegen": "node scripts/confect-codegen-sidecar.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cloudflare": "npm test --workspace @metacrdt/cloudflare",
    "test:core": "npm test --workspace @metacrdt/core",
    "test:convex-package": "npm test --workspace @metacrdt/convex",
    "test:forma": "npm test --workspace @metacrdt/forma",
    "test:local": "npm test --workspace @metacrdt/local",
    "test:runtime": "npm test --workspace @metacrdt/runtime",
    "test:confect": "vitest run convex/confect.test.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@confect/core": "^8.0.0",
    "@confect/server": "^8.0.0",
    "@convex-dev/static-hosting": "^0.1.3",
    "convex": "^1.40.0",
    "effect": "^3.21.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@confect/cli": "^8.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "convex-test": "^0.0.53",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
