{
  "name": "convex-triples",
  "version": "0.1.0",
  "description": "A reactive bitemporal triple store with a Datalog query engine, built on Convex.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "pnpm build:packages && convex dev",
    "dev:web": "vite",
    "build": "pnpm build:packages && pnpm build:app",
    "build:app": "vite build",
    "build:packages": "turbo run build --filter='./packages/*' --filter='./packages/@forma/*'",
    "preview": "vite preview",
    "deploy": "convex deploy",
    "deploy:forma": "pnpm --filter @forma/website deploy",
    "deploy:static": "static-hosting deploy",
    "confect:codegen": "node scripts/confect-codegen-sidecar.mjs",
    "test": "pnpm build:packages && vitest run",
    "test:watch": "vitest",
    "test:cloudflare": "pnpm --filter @metacrdt/cloudflare test",
    "test:core": "pnpm --filter @metacrdt/core test",
    "test:convex-package": "pnpm --filter @metacrdt/convex test",
    "test:collect": "pnpm --filter @metacrdt/collect test",
    "test:forma": "pnpm --filter @forma/ts test",
    "test:forma-host": "pnpm --filter @forma/host test",
    "test:local": "pnpm --filter @metacrdt/local test",
    "test:query": "pnpm --filter @metacrdt/query test",
    "test:runtime": "pnpm --filter @metacrdt/runtime test",
    "test:schema": "pnpm --filter @metacrdt/schema test",
    "test:workflow": "pnpm --filter @metacrdt/workflow test",
    "test:confect": "vitest run convex/confect.test.ts convex/complianceConfect.test.ts",
    "test:packages": "turbo run test --filter='./packages/*' --filter='./packages/@forma/*'",
    "test:all": "pnpm test:packages && pnpm test",
    "pack:packages": "turbo run pack:check --filter='./packages/*' --filter='./packages/@forma/*'",
    "typecheck": "pnpm build:packages && pnpm typecheck:packages && tsc --noEmit -p tsconfig.json",
    "typecheck:packages": "turbo run typecheck --filter='./packages/*' --filter='./packages/@forma/*'"
  },
  "license": "MIT",
  "dependencies": {
    "@confect/core": "^8.0.0",
    "@confect/server": "^8.0.0",
    "@convex-dev/better-auth": "^0.12.3",
    "@convex-dev/static-hosting": "^0.1.3",
    "@metacrdt/collect": "workspace:*",
    "@metacrdt/convex": "workspace:*",
    "@metacrdt/core": "workspace:*",
    "@metacrdt/query": "workspace:*",
    "@metacrdt/schema": "workspace:*",
    "@metacrdt/views": "workspace:*",
    "@metacrdt/workflow": "workspace:*",
    "better-auth": "~1.6.15",
    "convex": "^1.40.0",
    "effect": "^3.21.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@confect/cli": "^8.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@metacrdt/testkit": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "convex-test": "^0.0.53",
    "rolldown": "^1.1.0",
    "tailwindcss": "^4.3.0",
    "tsdown": "^0.22.2",
    "turbo": "^2.9.16",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@convex-dev/static-hosting",
      "@parcel/watcher",
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
