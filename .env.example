# Local Convex deployment metadata written by `pnpm exec convex dev`.
CONVEX_DEPLOYMENT=dev:your-deployment-name

# Convex client URL for Vite.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Better Auth HTTP origin. For local Vite, this should be the Convex `.site`
# URL. When the app is served by Convex static hosting, the frontend can derive
# this from window.location.origin.
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site
